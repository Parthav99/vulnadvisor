# Copy to platform/.env and adjust. Real .env is gitignored; never commit secrets.

# Async SQLAlchemy URL for the platform DB (matches docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://vulnadvisor:vulnadvisor@localhost:5432/vulnadvisor

# Set to true to echo SQL (dev debugging only).
DB_ECHO=false

# Triage copilot (Task 15.1). Shared service token the dashboard presents at the grant
# endpoint (set the same value as COPILOT_SERVICE_TOKEN in the dashboard's env). Empty
# disables the grant endpoint. Generate with e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
COPILOT_SERVICE_TOKEN=
# Per-org daily cap on copilot requests.
COPILOT_DAILY_CAP=50
