# Copy to .env.local. Real .env files are gitignored.

# Platform API base URL used during server-side rendering (server -> API).
API_URL=http://localhost:8000

# Browser-reachable API base URL for links the user navigates to (OAuth login, App install).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: an org-scoped API key so the dashboard can render without an interactive GitHub login
# (handy for local dev / previews). Leave unset to rely on the session cookie from OAuth.
# DASHBOARD_API_TOKEN=va_xxx.yyy
