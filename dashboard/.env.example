# Copy to .env.local. Real .env files are gitignored.

# Platform API base URL. Used for BOTH server-side rendering (server -> API) AND as the
# destination of the /api/* proxy in next.config.ts (the browser hits /api on this origin,
# which forwards to API_URL). The OAuth flow goes through that proxy so the session cookie is
# scoped to the dashboard's own domain.
API_URL=http://localhost:8000

# Optional / legacy: previously used for browser login links. Login/install now use the
# same-origin /api proxy, so this is no longer required. Safe to leave unset.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: an org-scoped API key so the dashboard can render without an interactive GitHub login
# (handy for local dev / previews). Leave unset to rely on the session cookie from OAuth.
# DASHBOARD_API_TOKEN=va_xxx.yyy

# Triage copilot (Task 15.1).
# Shared service token for the platform's copilot grant endpoint (must equal the platform's
# COPILOT_SERVICE_TOKEN). Without it /api/copilot returns 503.
COPILOT_SERVICE_TOKEN=
# Platform-fallback model key used when an org has no BYO key. Server-side only.
# Anthropic (sk-ant-...) preferred; an OpenAI key (OPENAI_API_KEY) also works — the
# provider is detected from the key's vendor prefix. Org BYO keys stay Anthropic-only.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Optional model override for the copilot (defaults to claude-opus-4-8).
# COPILOT_MODEL=claude-opus-4-8
